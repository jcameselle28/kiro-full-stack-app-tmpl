__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ---- Node / TypeScript ----
node_modules/
.npm/
.pnpm-store/
.yarn/
*.tsbuildinfo
.next/
out/
coverage/
.turbo/
