{
  "enabled": true,
  "name": "Lint Python on Save",
  "description": "Runs ruff check on Python files when they are saved, reporting any linting or formatting issues.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "ruff check --fix ${file}"
  }
}