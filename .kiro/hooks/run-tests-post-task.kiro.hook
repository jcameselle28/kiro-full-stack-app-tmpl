{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Automatically runs the project test suite after a spec task completes. Detects Python (pytest) or Node.js (npm test) projects.",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "if [ -f \"pyproject.toml\" ] || [ -f \"requirements.txt\" ]; then pytest -x -q 2>/dev/null || true; elif [ -f \"package.json\" ]; then npm test 2>/dev/null || true; fi"
  }
}