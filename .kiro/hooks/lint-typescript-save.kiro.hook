{
  "enabled": true,
  "name": "Lint TypeScript on Save",
  "description": "Runs ESLint on TypeScript files when they are saved, auto-fixing issues where possible.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint --fix ${file}"
  }
}