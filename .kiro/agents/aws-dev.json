{
  "name": "aws-dev",
  "description": "Application development agent for full-stack web apps running on AWS (EC2, RDS, ALB, CloudFront, WAF). Helps write, review, and refactor application code in Python and TypeScript/Node.js, plus the IaC that provisions the app.",
  "prompt": "file://./aws-dev-prompt.md",
  "mcpServers": {
    "aws": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@1.6.3",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--read-only",
        "--region",
        "us-east-1"
      ],
      "env": {}
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "@aws"
  ],
  "allowedTools": [
    "read",
    "write",
    "@aws"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "src/**",
        "lib/**",
        "tests/**",
        "infrastructure/**",
        "cdk/**",
        "scripts/**",
        "*.py",
        "*.ts",
        "*.tsx",
        "*.js",
        "*.json",
        "*.yaml",
        "*.yml",
        "*.toml",
        "*.cfg",
        "Dockerfile",
        "docker-compose.yml",
        "Makefile"
      ]
    }
  },
  "resources": [
    "skill://../skills/aws-dev/SKILL.md",
    "skill://../skills/testing-ci/SKILL.md",
    "file://src/**",
    "file://lib/**",
    "file://infrastructure/**"
  ],
  "model": "claude-sonnet-4-5"
}
