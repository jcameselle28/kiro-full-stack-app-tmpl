{
  "name": "sre",
  "description": "Site Reliability Engineering sub-agent. Handles observability, SLOs/SLIs, error budgets, incident management, postmortems, runbooks, alerting, and toil reduction.",
  "prompt": "file://./sre-prompt.md",
  "mcpServers": {
    "cloudwatch": {
      "command": "uvx",
      "args": ["awslabs.cloudwatch-mcp-server@latest"],
      "env": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "cloudwatch-appsignals": {
      "command": "uvx",
      "args": ["awslabs.cloudwatch-applicationsignals-mcp-server@latest"],
      "env": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "prometheus": {
      "command": "uvx",
      "args": ["awslabs.prometheus-mcp-server@latest"],
      "env": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "cloudtrail": {
      "command": "uvx",
      "args": ["awslabs.cloudtrail-mcp-server@latest"],
      "env": { "FASTMCP_LOG_LEVEL": "ERROR" }
    },
    "aws-documentation": {
      "command": "uvx",
      "args": ["awslabs.aws-documentation-mcp-server@latest"],
      "env": { "FASTMCP_LOG_LEVEL": "ERROR" }
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "aws",
    "@cloudwatch",
    "@cloudwatch-appsignals",
    "@prometheus",
    "@cloudtrail",
    "@aws-documentation"
  ],
  "allowedTools": [
    "read",
    "aws",
    "@cloudwatch",
    "@cloudwatch-appsignals",
    "@prometheus",
    "@cloudtrail",
    "@aws-documentation"
  ],
  "toolsSettings": {
    "aws": {
      "allowedServices": [
        "cloudwatch", "logs", "xray", "synthetics", "application-signals",
        "health", "events", "ssm", "sts", "lambda", "sns",
        "cloudformation", "config"
      ],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "skill://../skills/aws-cli/SKILL.md",
    "file://runbooks/**/*.md",
    "file://docs/sre/**/*.md",
    "file://monitoring/**/*.yaml"
  ],
  "model": "claude-opus-4.6"
}